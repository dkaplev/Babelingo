# Copy to .env (this file is safe to commit; .env is gitignored).
# Enable for this key: Cloud Translation API, Speech-to-Text API, Text-to-Speech API.
#
# Name must be exactly GOOGLE_CLOUD_API_KEY on Render (Environment) — Linux is case-sensitive.
# Do NOT put this key in the Expo app; only EXPO_PUBLIC_PIPELINE_URL belongs in babel-party/.env

PORT=3847
GOOGLE_CLOUD_API_KEY=

# Optional: restrict CORS (comma-separated origins). Use your Expo dev URL or * for testing.
# CORS_ORIGIN=https://your-app.onrender.com

# Log client analytics POSTs to stdout (Phase 5 / production observability).
# LOG_ANALYTICS=1

# Optional: Apple shared secret for auto-renewable subscriptions (POST /validate-receipt).
# APPLE_SHARED_SECRET=

# Chaos score uses Gemini text-embedding-004 with the same GOOGLE_CLOUD_API_KEY (enable Generative Language API if needed).

# Bind address (default 0.0.0.0 — required in Docker / cloud).
# HOST=0.0.0.0
