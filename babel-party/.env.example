# Copy to .env — EXPO_PUBLIC_* are inlined at bundle time (restart Metro after changes).
# Local dev: your Mac LAN IP. Production: https://your-api.onrender.com (see Babelingo/DEPLOY.md).
#
# Never put GOOGLE_CLOUD_API_KEY here — only on the API server (Render Environment or babel-party-server/.env).

EXPO_PUBLIC_PIPELINE_URL=http://192.168.1.XXX:3847

# With EXPO_PUBLIC_PIPELINE_URL set, the app tries server /tts first (better loudspeaker). Set to 1 to force device TTS only.
# EXPO_PUBLIC_FORCE_DEVICE_PHRASE_TTS=1

# Optional: also try server TTS when the flag below is set (usually redundant if URL is set).
# EXPO_PUBLIC_USE_GOOGLE_TTS=1

# Optional: stop sending analytics to POST /analytics on your API.
# EXPO_PUBLIC_DISABLE_ANALYTICS=1
