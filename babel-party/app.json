{
  "expo": {
    "name": "Babelingo",
    "slug": "babelingo",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "babelingo",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#141544"
    },
    "ios": {
      "bundleIdentifier": "party.babelingo.app",
      "buildNumber": "6",
      "appleTeamId": "UDP2RKPHCF",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Babelingo records your phrase imitation for the Echo Translator reveal.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "party.babelingo.app",
      "versionCode": 4,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#141544",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6f9191ef-dc2e-4165-8d3c-7ab740572684"
      }
    },
    "owner": "sammyjoe5000"
  }
}
